{
  "info": {
    "name": "SADC Order Management API",
    "description": "Exercises the SADC OMS API. Run 'Auth / Get dev token' first to populate {{token}}; create requests save {{customerId}} and {{orderId}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5080" },
    { "key": "token", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get dev token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.accessToken);",
                  "pm.test('token issued', () => pm.expect(body.accessToken).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/dev/token", "host": ["{{baseUrl}}"], "path": ["api", "dev", "token"] }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('customerId', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Thandi Nkosi\",\n  \"email\": \"thandi@example.co.za\",\n  \"countryCode\": \"ZA\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        },
        {
          "name": "Get customer by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "{{customerId}}"] }
          }
        },
        {
          "name": "List customers (search + paginate)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/customers?search=Thandi&page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                { "key": "search", "value": "Thandi" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('orderId', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"currencyCode\": \"ZAR\",\n  \"lines\": [\n    { \"productSku\": \"SKU-TEE-001\", \"quantity\": 3, \"unitPrice\": 149.99 },\n    { \"productSku\": \"SKU-CAP-002\", \"quantity\": 2, \"unitPrice\": 89.50 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] }
          }
        },
        {
          "name": "List orders (filter + sort + paginate)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?status=Pending&page=1&pageSize=10&sort=createdAt_desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "Pending" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "sort", "value": "createdAt_desc" }
              ]
            }
          }
        },
        {
          "name": "Update order status (idempotent)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Paid\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "status"] }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Orders total in ZAR",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/reports/orders/zar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "orders", "zar"]
            }
          }
        }
      ]
    }
  ]
}
